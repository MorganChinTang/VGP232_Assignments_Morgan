<Window x:Name="MainWindow1" x:Class="Assignment3_Morgan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Assignment3_Morgan"
        xmlns:input="clr-namespace:System.Windows.Input;assembly=PresentationCore"
        mc:Ignorable="d"
        Title="Sprite Sheet Generator" Height="450" Width="550"
        Closing="Window_Closing">
    <Window.InputBindings>
        <KeyBinding Command="{x:Static input:ApplicationCommands.New}" Modifiers="Control" Key="N" />
        <KeyBinding Command="{x:Static input:ApplicationCommands.Open}" Modifiers="Control" Key="O" />
        <KeyBinding Command="{x:Static input:ApplicationCommands.Save}" Modifiers="Control" Key="S" />
    </Window.InputBindings>
    <DockPanel>
        <Menu x:Name="Toolbar" DockPanel.Dock="Top" Height="20">
            <MenuItem Header="_File" HorizontalAlignment="Stretch">
                <MenuItem Header="_New" Command="{x:Static input:ApplicationCommands.New}" InputGestureText="Ctrl+N" />
                <MenuItem Header="_Open..." Command="{x:Static input:ApplicationCommands.Open}" InputGestureText="Ctrl+O" />
                <MenuItem x:Name="menuItemSave" Header="_Save" Command="{x:Static input:ApplicationCommands.Save}" InputGestureText="Ctrl+S" IsEnabled="False" />
                <MenuItem Header="Save _As..." Command="{x:Static input:ApplicationCommands.SaveAs}" InputGestureText="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Header="E_xit" Click="ExitMenu_Click" />
            </MenuItem>
            <MenuItem Header="_Edit" HorizontalAlignment="Stretch">
                <MenuItem Header="_Undo" Command="{x:Static input:ApplicationCommands.Undo}" InputGestureText="Ctrl+Z" />
                <MenuItem Header="_Redo" Command="{x:Static input:ApplicationCommands.Redo}" InputGestureText="Ctrl+Y" />
                <Separator />
                <MenuItem Header="_Copy" Command="{x:Static input:ApplicationCommands.Copy}" InputGestureText="Ctrl+C" />
                <MenuItem Header="_Paste" Command="{x:Static input:ApplicationCommands.Paste}" InputGestureText="Ctrl+V" />
                <Separator />
                <MenuItem Header="_Remove" Command="{x:Static local:MainWindow.RemoveCommand}" InputGestureText="Del" />
                <MenuItem Header="Remove _All" Command="{x:Static local:MainWindow.RemoveAllCommand}" InputGestureText="Ctrl+Del" />
            </MenuItem>
        </Menu>

        <Grid Margin="20,20,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="118*"/>
                <ColumnDefinition Width="145*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" MinHeight="27.96" />
                <RowDefinition Height="Auto" MinHeight="25.96" />
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <TextBlock x:Name="txtProjectName" Grid.Row="0" FontWeight="SemiBold" Margin="0,0,0,20" Grid.ColumnSpan="2" />

            <Grid Grid.Row="1" Margin="0,0,0,20" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="tbOutputDirTitle" Text="Output Directory" VerticalAlignment="Center" />
                <TextBox x:Name="tbOutputDir" Grid.Column="1" Margin="6,0,6,0" Height="25" VerticalContentAlignment="Center" />
                <Button x:Name="bBrowse" Grid.Column="2" Width="90" Content="Browse..." Click="Browse_Click" />
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,0,20" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="tbTilename" Text="Filename (.png)" VerticalAlignment="Center" />
                <TextBox x:Name="tbOutputFile" Grid.Column="1" Margin="6,0,0,0" Text="SpriteSheet.png" Height="25" VerticalContentAlignment="Center" />
            </Grid>

            <Grid Grid.Row="3" Margin="0,0,0,20" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="tbColumn" Text="Columns" VerticalAlignment="Center" />
                <TextBox x:Name="tbColumnsInput" Grid.Column="1" Margin="6,0,0,0" Text="1" Height="25" VerticalContentAlignment="Center" />
                <CheckBox x:Name="cbIncludeMetaData" Grid.Column="2" Content="include meta data (.json)" Margin="12,0,0,0" VerticalAlignment="Center" />
            </Grid>

            <Grid x:Name="grid1" Grid.Row="4" Grid.ColumnSpan="2" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ListBox x:Name="lbSprites" Grid.Column="0" Height="140" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Disabled" VerticalAlignment="Top">
                    <ListBox.InputBindings>
                        <KeyBinding Command="{x:Static input:ApplicationCommands.Undo}" Modifiers="Control" Key="Z" />
                        <KeyBinding Command="{x:Static input:ApplicationCommands.Redo}" Modifiers="Control" Key="Y" />
                        <KeyBinding Command="{x:Static input:ApplicationCommands.Copy}" Modifiers="Control" Key="C" />
                        <KeyBinding Command="{x:Static input:ApplicationCommands.Paste}" Modifiers="Control" Key="V" />
                        <KeyBinding Command="{x:Static local:MainWindow.RemoveCommand}" Key="Delete" />
                        <KeyBinding Command="{x:Static local:MainWindow.RemoveAllCommand}" Modifiers="Control" Key="Delete" />
                    </ListBox.InputBindings>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" IsItemsHost="True" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Image Width="110" Height="80" Stretch="Uniform" Source="{Binding Preview}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="4" />
                            <Setter Property="BorderThickness" Value="2" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="Padding" Value="2" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#F39C12" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#9E9E9E" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top">
                    <Button x:Name="bAdd" Width="90" Margin="0,0,0,8" Content="Add" Click="Add_Click" />
                    <Button x:Name="bRemove" Width="90" Margin="0,0,0,8" Content="Remove" Click="Remove_Click" />
                    <Button x:Name="bGenerate" Width="90" Content="Generate" Click="Generate_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
