<Window x:Class="Assignment2C.WeaponEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weapon Editor" Height="420" Width="520" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Margin="0,0,8,8" VerticalAlignment="Center" />
            <TextBox Grid.Row="0" Grid.Column="1" Name="NameTextBox" Margin="0,0,0,8" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Type" Margin="0,0,8,8" VerticalAlignment="Center" />
            <ComboBox Grid.Row="1" Grid.Column="1" Name="TypeComboBox" Margin="0,0,0,8" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Image URL" Margin="0,0,8,8" VerticalAlignment="Center" />
            <TextBox Grid.Row="2" Grid.Column="1" Name="ImageTextBox" Margin="0,0,0,8" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Rarity" Margin="0,0,8,8" VerticalAlignment="Center" />
            <TextBox Grid.Row="3" Grid.Column="1" Name="RarityTextBox" Margin="0,0,0,8" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Base Attack" Margin="0,0,8,8" VerticalAlignment="Center" />
            <TextBox Grid.Row="4" Grid.Column="1" Name="BaseAttackTextBox" Margin="0,0,0,8" />

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Secondary Stat" Margin="0,0,8,8" VerticalAlignment="Center" />
            <TextBox Grid.Row="5" Grid.Column="1" Name="SecondaryStatTextBox" Margin="0,0,0,8" />

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Passive" Margin="0,0,8,0" VerticalAlignment="Center" />
            <TextBox Grid.Row="6" Grid.Column="1" Name="PassiveTextBox" />
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Name="SaveButton" Content="Save" Width="90" Margin="0,0,8,0" Click="SaveClicked" IsDefault="True" />
            <Button Name="CancelButton" Content="Cancel" Width="90" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
